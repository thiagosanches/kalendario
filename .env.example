# Environment file for Docker deployment
# Copy this to .env and fill in your actual keys

# Telegram Bot Token (get from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# OpenAI API Key (get from https://platform.openai.com/api-keys)
# Only needed if you want voice message support
OPENAI_API_KEY=your_openai_api_key_here

# OPTIONAL: Whitelist of allowed users (comma-separated User IDs)
# If not set, anyone can use the bot
# If set, only these users can interact with the bot
# Get your User ID by sending /start to the bot
# Example: ALLOWED_USERS=123456789,987654321,456789123
ALLOWED_USERS=

# Note: The bot now supports multiple users automatically.
# Each user gets their own appointments and reminders.
# Use ALLOWED_USERS to restrict access to specific people.
